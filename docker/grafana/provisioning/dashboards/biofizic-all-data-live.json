  "panels": [
    {
      "id": 1,
      "title": "Raw PPG (green) with detected peaks",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, ppg_green FROM biofizic_all_data_live WHERE $__timeFilter(time) AND ppg_green IS NOT NULL ORDER BY time",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, ppg_peak FROM biofizic_all_data_live WHERE $__timeFilter(time) AND ppg_peak IS NOT NULL ORDER BY time",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {

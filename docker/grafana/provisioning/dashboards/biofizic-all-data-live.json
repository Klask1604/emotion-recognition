          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, ibi_ms FROM biofizic_all_data_live WHERE $__timeFilter(time) AND ibi_ms IS NOT NULL ORDER BY time",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"

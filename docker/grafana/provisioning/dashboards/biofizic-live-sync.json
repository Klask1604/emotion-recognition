          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, hr_sdk FROM biofizic_live WHERE $__timeFilter(time) AND hr_sdk > 0 ORDER BY time",

  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "RMSSD per window — convergence = stable HRV",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, w30_rmssd, w60_rmssd, w90_rmssd FROM biofizic_state_windows WHERE $__timeFilter(time) AND w30_rmssd > 0 ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "decimals": 1,
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },

{
  "id": null,
  "uid": "biofizic-baseline-compare",
  "title": "Biofizic Baseline Compare",
  "tags": [
    "biofizic",
    "baseline"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Kubios vs baseline labels (text)",
      "type": "state-timeline",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "table",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, emotion, emotion_baseline FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 75,
            "lineWidth": 0
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "rowHeight": 0.85,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 2,
      "title": "Label levels (1=Relaxat … 5=Ridicat) + agreement",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, CASE emotion   WHEN 'Relaxat' THEN 1   WHEN 'Echilibrat' THEN 2   WHEN 'Moderat' THEN 3   WHEN 'Alert' THEN 4   WHEN 'Ridicat' THEN 5   ELSE 0 END AS kubios_label, CASE emotion_baseline   WHEN 'Relaxat' THEN 1   WHEN 'Echilibrat' THEN 2   WHEN 'Moderat' THEN 3   WHEN 'Alert' THEN 4   WHEN 'Ridicat' THEN 5   ELSE 0 END AS baseline_label FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, labels_agree * 5 AS labels_agree_scaled FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "decimals": 0,
          "min": 0,
          "max": 5
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "title": "Stress index vs personal baseline",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, stress_index AS si_kubios FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, baseline_si AS si_baseline FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "title": "Stress index z-score",

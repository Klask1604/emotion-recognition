        "w": 24,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "influxdb",
        "uid": "biofizic-influx"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "biofizic-influx"
          },
          "editorMode": "code",
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time, z_si FROM biofizic_state WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "decimals": 2,
          "min": -3,
